alias ghs='github-switch'
alias z='zellij'
alias gp='git pull'
alias gpush='git push'
alias st='git status'
alias stt='git status -uno'
alias ll='ls -la'
alias gpl='git pull --prune'
alias gc='git commit'
alias ga='git add --all'
alias gdp='git checkout development && git pull --prune'
alias clauded='claude --dangerously-skip-permissions'
alias cdroot='cd $(git rev-parse --show-toplevel)'
alias claudepr='claude --allowed-tools "Read Bash(gh pr create:*) Bash(git push:*) Bash(git diff:*)" --model haiku -p "現在のブランチからmainに対するPRを作成して。pushをし、gh pr createコマンドで作成してください。エラーにならない限りDraftで作成してください。タイトルや内容は変更内容から類推してください。コードの変更・コミットは許されません。作成後は、PRのURLを教えてください。リポジトリにテンプレートがある場合は必ずそれを利用すること。日本語で記述すること。"'
alias reload='source ~/.zshrc'
