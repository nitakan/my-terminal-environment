#!/bin/bash
set -euo pipefail

# Usage: aipr [-b base_branch] [追加指示...]
#   -b: PR先のブランチ（省略時: リポジトリのデフォルトブランチ）
#   残りの引数: Claude への追加指示

# スピナー表示
SPIN_PID=""
show_spinner() {
    local msg="$1"
    local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    while true; do
        printf "\r  %s %s" "${chars:i%${#chars}:1}" "$msg" >&2
        i=$((i + 1))
        sleep 0.1
    done
}
cleanup_spinner() {
    if [ -n "$SPIN_PID" ]; then
        kill "$SPIN_PID" 2>/dev/null || true
        wait "$SPIN_PID" 2>/dev/null || true
        printf '\r\033[K' >&2
        SPIN_PID=""
    fi
}

base_branch=""

while getopts "b:" opt; do
    case $opt in
        b) base_branch="$OPTARG" ;;
        *) echo "Usage: aipr [-b base_branch] [追加指示...]" >&2; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

# デフォルトブランチの解決
show_spinner "PR作成を準備中..." &
SPIN_PID=$!
trap 'cleanup_spinner' EXIT

if [ -z "$base_branch" ]; then
    base_branch=$(gh repo view --json defaultBranchRef -q '.defaultBranchRef.name')
fi

# プロンプト構築
base_prompt="現在のブランチから${base_branch}に対するPRを作成して。pushをし、gh pr createコマンドで作成してください。エラーにならない限りDraftで作成してください。タイトルや内容は変更内容から類推してください。コードの変更・コミットは許されません。作成後は、PRのURLを教えてください。リポジトリにテンプレートがある場合は必ずそれを利用すること。日本語で記述すること。"

if [ $# -gt 0 ]; then
    prompt="${base_prompt} 追加指示: $*"
else
    prompt="$base_prompt"
fi

cleanup_spinner
trap - EXIT

claude \
    --no-session-persistence \
    --allowed-tools "Read Bash(gh pr create:*) Bash(git push:*) Bash(git diff:*) Bash(git log:*)" \
    --model haiku \
    -p "$prompt"
